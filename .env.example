# Create these with `npx convex dev`.
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Create a Clerk application, then enable its Convex JWT template/integration.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=

# Comma-separated verified Clerk emails allowed to open the admin panel.
# Set this in the Convex deployment environment.
ADMIN_EMAILS=

# Stripe server key used to create and verify hosted Checkout sessions.
STRIPE_SECRET_KEY=

# Text and image safety checks run locally and require no external API key.
